# ============================================================================
# KS-RAG Local Development Environment
# ============================================================================
# Copy this to .env.local for local development
# Includes sensible defaults for Mac/Linux/Windows development
# ============================================================================

# DATABASE CONFIGURATION
# Uses local MongoDB (assumes `mongod` is running locally)
MONGO_URI=mongodb://localhost:27017

# AUTHENTICATION & JWT
# Local dev secret (NOT FOR PRODUCTION!)
SECRET_KEY=local-dev-secret-key-super-insecure
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OPENMETADATA INTEGRATION
# Local OpenMetadata instance or Docker container
OPENMETADATA_URL=http://localhost:8585
OPENMETADATA_TOKEN=local-dev-token

# WEBHOOK SIGNATURES & SECURITY
# Use any string for local testing
DBT_WEBHOOK_SECRET=local-dbt-secret-for-testing
GITHUB_WEBHOOK_SECRET=local-github-secret-for-testing

# GITHUB APP CONFIGURATION
# These won't work with real GitHub, but suitable for local testing
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----

# AI/LLM CONFIGURATION
AI_MODEL=claude-3-sonnet-20240229

# Use your actual API keys for local testing
CLAUDE_API_KEY=sk-ant-your-real-claude-key-for-local-testing
OPENAI_API_KEY=sk-your-real-openai-key-for-local-testing

# LOGGING & DEBUG
LOG_LEVEL=DEBUG
DEBUG=true

# APPLICATION SETTINGS
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000"]

# RATE LIMITING & QUOTAS
RATE_LIMIT_RPM=1000
INVESTIGATION_TIMEOUT_SECONDS=600
MAX_LINEAGE_DEPTH=5

# CACHE & OPTIMIZATION
ENABLE_CACHE=false
