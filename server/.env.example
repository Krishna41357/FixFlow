# ============================================================================
# KS-RAG Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB connection string
# Format: mongodb://[username]:[password]@[host]:[port]/[database]
# Local development: mongodb://localhost:27017
# Atlas cloud: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================
# Secret key for JWT token signing
# IMPORTANT: Change this in production! Use a strong, random string.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# OPENMETADATA INTEGRATION
# ============================================================================
# These can be overridden per-connection in the database, but defaults here:
# OpenMetadata service URL
OPENMETADATA_URL=https://metadata.example.com

# OpenMetadata service token (API key)
OPENMETADATA_TOKEN=your-openmetadata-api-token

# OpenMetadata timeout for API calls (seconds)
OPENMETADATA_API_TIMEOUT=30

# ============================================================================
# WEBHOOK SIGNATURES & SECURITY
# ============================================================================
# dbt Cloud webhook secret for signature validation
# Generate a random string in dbt Cloud webhook settings
DBT_WEBHOOK_SECRET=dbt-webhook-secret-from-cloud-settings

# GitHub webhook secret for signature validation
# Generate in GitHub App settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=github-webhook-secret-from-app-settings

# ============================================================================
# GITHUB APP CONFIGURATION
# ============================================================================
# GitHub App ID (numeric ID from GitHub App settings)
GITHUB_APP_ID=123456

# GitHub App Private Key (PEM format, multi-line)
# Copy from GitHub App settings → Private keys → Generate private key
# Replace \n with actual newlines when setting in .env
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----

# ============================================================================
# AI/LLM CONFIGURATION
# ============================================================================
# AI Model to use: "claude-3-sonnet-20240229", "gpt-4-turbo", etc.
AI_MODEL=claude-3-sonnet-20240229

# Anthropic Claude API key
# Get from: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=sk-ant-your-claude-api-key

# OpenAI API key (for GPT models)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable debug mode (verbose logging, detailed error messages)
DEBUG=false

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Application environment: development, staging, production
APP_ENV=development

# FastAPI host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Enable CORS for frontend development
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# ============================================================================
# OPTIONAL: EMAIL & NOTIFICATIONS
# ============================================================================
# SMTP configuration for email notifications (future feature)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@ksrag.example.com

# Slack webhook for notifications (future feature)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# OPTIONAL: RATE LIMITING & QUOTAS
# ============================================================================
# Rate limit: requests per minute per user
RATE_LIMIT_RPM=60

# Investigation processing timeout (seconds)
INVESTIGATION_TIMEOUT_SECONDS=300

# Max investigation depth (lineage traversal)
MAX_LINEAGE_DEPTH=5

# ============================================================================
# OPTIONAL: CACHE & OPTIMIZATION
# ============================================================================
# Redis URL for caching (optional)
# Format: redis://[:password]@hostname:port/db
REDIS_URL=redis://localhost:6379/0

# Enable result caching
ENABLE_CACHE=false

# Cache TTL in seconds
CACHE_TTL_SECONDS=3600
